{
  "app": {
    "name": "MAX",
    "version": "1.1.0",
    "description": "Simple Local AI Assistant",
    "mode": "simple",
    "auto_start": true,
    "theme": "dark"
  },
  "ai": {
    "provider": "ollama",
    "model": "qwen2.5:7b",
    "fallback_enabled": true,
    "max_tokens": 2048,
    "temperature": 0.7
  },
  "ui": {
    "language": "auto",
    "font_size": "medium",
    "animations": true,
    "compact_mode": false,
    "show_tips": true
  },
  "privacy": {
    "local_only": true,
    "data_retention_days": 30,
    "analytics": false,
    "crash_reports": false
  },
  "performance": {
    "cache_enabled": true,
    "max_memory_mb": 2048,
    "connection_timeout": 30,
    "retry_attempts": 3
  },
  "features": {
    "voice_input": false,
    "voice_output": false,
    "file_upload": true,
    "web_search": false,
    "plugins": false
  },
  "network": {
    "port": 8000,
    "host": "127.0.0.1",
    "cors_enabled": true,
    "rate_limit": {
      "enabled": true,
      "requests_per_minute": 60
    }
  }
}
